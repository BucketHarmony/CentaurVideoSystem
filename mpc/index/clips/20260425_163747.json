  "transcript": {
    "language": "en",
    "language_probability": 0.991,
    "duration_s": 29.8453125,
    "text": "Do not know who I am. My name is Donovan McKinney. I currently serve as a state representative in the 11th House District. If you know anything about 8 Mile, you heard about the 8 Mile movie? Yeah, come on. That's my district. So I represent M&M's Old Trailer Park and Warren also represent where he grew up at on the other side of 8 Mile in Detroit. Let me tell you why I'm here. ICE is not new to our community. So how many people know that?",
    "segments": [
      {
        "start": 0.0,
        "end": 1.68,
        "text": "Do not know who I am."
      },
      {
        "start": 1.68,
        "end": 3.44,
        "text": "My name is Donovan McKinney."
      },
      {
        "start": 3.44,
        "end": 7.24,
        "text": "I currently serve as a state representative in the 11th House District."
      },
      {
        "start": 7.24,
        "end": 10.64,
        "text": "If you know anything about 8 Mile, you heard about the 8 Mile movie?"
      },
      {
        "start": 10.64,
        "end": 12.08,
        "text": "Yeah, come on."
      },
      {
        "start": 12.08,
        "end": 13.08,
        "text": "That's my district."
      },
      {
        "start": 13.08,
        "end": 16.28,
        "text": "So I represent M&M's Old Trailer Park and"
      },
      {
        "start": 16.28,
        "end": 21.56,
        "text": "Warren also represent where he grew up at on the other side of 8 Mile in Detroit."
      },
      {
        "start": 21.56,
        "end": 26.42,
        "text": "Let me tell you why I'm here."
      },
      {
        "start": 26.42,
        "end": 28.58,
        "text": "ICE is not new to our community."
      },
      {
        "start": 28.58,
        "end": 29.58,
        "text": "So how many people know that?"
      }
    ]
  },
