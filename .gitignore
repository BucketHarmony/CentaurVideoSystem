# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ComfyUI framework (its own git repo — we track our files separately)
ComfyUI/

# Windows
*.lnk
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/

# Demo output (generated, not tracked)
demo/output/

# MPC pipeline — source footage and generated artifacts
raw/
mpc/index/thumbnails/

# cvs_lib regression baselines — binary blobs (PNGs, WAVs).
# Hashes live in tests/cvs_lib/fixtures/baseline_manifest.json (tracked).
# Regenerate via tests/cvs_lib/capture_baselines.py.
tests/cvs_lib/fixtures/baselines/

# Claude Code — machine-local config / runtime locks (agents/ is tracked)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Misc
*.log
*.tmp
