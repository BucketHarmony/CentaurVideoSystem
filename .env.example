# Centaur Video System — Environment Configuration
# Copy this file to .env and fill in your values.

# ElevenLabs TTS (required for narration)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE=your_voice_id_here
ELEVENLABS_MODEL=eleven_multilingual_v2

# Bluesky Publishing (optional)
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

# Gmail (optional — for notifications)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
OPERATOR_EMAIL=your_email@gmail.com

# Project paths (override if your layout differs)
# KOMBUCHA_DIR=path/to/kombucha/ticks
